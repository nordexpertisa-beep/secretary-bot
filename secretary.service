[Unit]
Description=Secretary Telegram Bot (Obsidian Inbox)
After=network.target

[Service]
Type=simple
User=ann
WorkingDirectory=/home/ann/secretary-bot
EnvironmentFile=/home/ann/secretary-bot/.env
ExecStart=/home/ann/secretary-bot/venv/bin/python bot.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
